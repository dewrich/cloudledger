  "nodes": [
    {
      "doc_path": "context/index.md",
      "id": "cloudwatchr",
      "kind": "system",
      "name": "CloudWatchr",
      "owner": "observability-eng",
      "relations": [
        {
          "desc": "Reads aggregated AWS spend from CloudLedger's Costs domain API to evaluate budget rules",
          "kind": "reads",
          "tech": "HTTPS / REST (costs:view) — cross-repo, see externals/cloudledger-costs-api.md",
          "to": "cloudledger"
        }
      ],
      "source_path": "docs/context/index.md",
      "source_repo": "dewrich/cloudwatchr",
      "system": "cloudwatchr",
      "tags": [
        "finops",
        "alerting",
        "monitoring",
        "batch"
      ]
    },
    {
      "doc_path": "containers/alerter.md",
      "id": "cloudwatchr/alerter",
      "kind": "container",
      "name": "Alerter",
      "owner": "observability-eng",
      "relations": [
        {
          "desc": "Pulls spend rollups and daily cost rows to evaluate against budget rules (cross-repo)",
          "kind": "reads",
          "tech": "HTTPS / REST — GET /costs/rollups/by-service, /costs/daily (costs:view)",
          "to": "ext/cloudledger-costs-api"
        },
        {
          "desc": "Obtains a bearer token with costs:view so CloudLedger's API accepts the call",
          "kind": "uses",
          "tech": "Cognito client-credentials / OIDC",
          "to": "ext/aws-cognito"
        },
        {
          "desc": "Reads active rules; writes fired/cleared alert state (idempotent per rule × window)",
          "kind": "writes",
          "tech": "pgx",
          "to": "cloudwatchr/alert-state-db"
        }
      ],
      "source_path": "docs/containers/alerter.md",
      "source_repo": "dewrich/cloudwatchr",
      "system": "cloudwatchr",
      "tags": [
        "batch",
        "finops",
        "evaluation"
      ],
      "tech": "Go 1.23 / ECS Scheduled Task (EventBridge cron, every 15 min)"
    },
    {
      "doc_path": "containers/notifier.md",
      "id": "cloudwatchr/notifier",
      "kind": "container",
      "name": "Notifier",
      "owner": "observability-eng",
      "relations": [
        {
          "desc": "Reads newly fired/cleared alerts to deliver; marks them delivered",
          "kind": "reads",
          "tech": "pgx (LISTEN/NOTIFY on state change)",
          "to": "cloudwatchr/alert-state-db"
        },
        {
          "desc": "Posts alert messages to the configured Slack channels",
          "kind": "uses",
          "tech": "Slack Incoming Webhooks",
          "to": "ext/slack"
        },
        {
          "desc": "Opens/resolves incidents for high-severity budget breaches",
          "kind": "uses",
          "tech": "PagerDuty Events API v2",
          "to": "ext/pagerduty"
        }
      ],
      "source_path": "docs/containers/notifier.md",
      "source_repo": "dewrich/cloudwatchr",
      "system": "cloudwatchr",
      "tags": [
        "http",
        "delivery",
        "alerting"
      ],
      "tech": "Go 1.23 / Fiber (webhook receiver) + worker (delivery)"
    },
